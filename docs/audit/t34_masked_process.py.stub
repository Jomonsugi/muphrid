"""
T34 — masked_process  [PROTOTYPE STUB — not production]

Meta-tool that removes the 3-step friction of masked processing:
  old: create_mask → primary_tool → pixel_math blend (agent assembles manually)
  new: masked_process(tool_name="multiscale_process", mask=..., tool_params={...})

Registers in both LINEAR_TOOLS and NONLINEAR_TOOLS.

Why this matters: the M20 run used zero masks. Doctrine is a big part of that, but
so is ergonomics — the agent is trained to minimize steps and a 3-call chain reads
as "expensive" when weighed against "just push the parameters harder." A single
tool call with masked semantics makes the pro workflow cheaper than the naive one.

Design notes
------------
- The mask parameter accepts either:
    (a) an existing mask file path (e.g. from a previous create_mask call), or
    (b) an inline MaskSpec that is created on the fly by delegating to create_mask.
- The primary tool is invoked via the LangGraph tool registry by name. Its output
  is compared against the pre-image and blended with the mask.
- Blending formula: out = processed * mask + original * (1 - mask)
  with an optional `blend_alpha` [0..1] that scales the mask strength.
- Output filename follows the same *_suffix convention as other variant-producing
  tools so variant_snapshot and the HITL gate pool behave correctly.

Limitations
-----------
- Primary tool must accept a current_image in state and produce a new FITS file —
  most processing tools do. Tools that mutate state in non-file ways (commit_variant,
  present_images) are not valid primaries.
- Some primary tools produce multi-file outputs (e.g. star_removal produces starless
  + mask). masked_process wraps only tools where the "primary output" is unambiguous.
- The blend happens in the working color space (usually sRGB non-linear post-stretch).
  Linear-space masked operations need a pre-stretch mask.
"""

from __future__ import annotations

import json
from pathlib import Path
from typing import Annotated, Any

from langchain_core.messages import ToolMessage
from langchain_core.tools import tool
from langchain_core.tools.base import InjectedToolCallId
from langgraph.prebuilt import InjectedState
from langgraph.types import Command
from pydantic import BaseModel, Field

from muphrid.graph.state import AstroState


# NOTE: MaskSpec mirrors CreateMaskInput in t25_create_mask. In the real patch,
# import directly and delegate. This stub keeps the shape visible inline.
class MaskSpec(BaseModel):
    mask_type: str = Field(description="luminance, inverted_luminance, range, channel_diff")
    range_low: float = 0.0
    range_high: float = 1.0
    feather_radius: float = 3.0
    # ... full field list in t25_create_mask.py


class MaskedProcessInput(BaseModel):
    tool_name: str = Field(
        description=(
            "Name of the primary tool to apply inside the mask. "
            "Supported: multiscale_process, local_contrast_enhance, curves_adjust, "
            "saturation_adjust, noise_reduction (linear phase only), stretch_image."
        ),
    )
    tool_params: dict[str, Any] = Field(
        default_factory=dict,
        description=(
            "Parameters passed through to the primary tool. "
            "Must match the primary tool's input schema."
        ),
    )
    mask: str | MaskSpec = Field(
        description=(
            "Either an absolute path to an existing mask FITS file, or a MaskSpec "
            "that will be materialized via create_mask before blending."
        ),
    )
    blend_alpha: float = Field(
        default=1.0,
        description=(
            "Mask strength. 1.0 = full mask effect (processed inside, original outside). "
            "0.5 = gentle blend (50% processed, 50% original everywhere in-mask). "
            "Useful for softening aggressive operations."
        ),
    )
    output_suffix: str | None = Field(
        default=None,
        description="Suffix for the output file. Auto-generated from tool_name if None.",
    )


@tool(args_schema=MaskedProcessInput)
def masked_process(
    tool_name: str,
    tool_params: dict,
    mask: str | dict,
    blend_alpha: float = 1.0,
    output_suffix: str | None = None,
    tool_call_id: Annotated[str, InjectedToolCallId] = None,
    state: Annotated[AstroState, InjectedState] = None,
) -> Command:
    """
    Apply a processing tool only inside a mask, blending with the original outside.

    Removes the manual 3-step pattern (create_mask → tool → pixel_math) by wiring
    the steps together. The agent expresses intent: "sharpen with multiscale_process
    inside this nebula-luminance mask with full effect." Muphrid assembles the chain.

    Example — sharpen nebula only, don't touch background:
        masked_process(
            tool_name="multiscale_process",
            tool_params={
                "num_scales": 5,
                "operations": [
                    {"scale": 1, "op": "passthrough"},
                    {"scale": 2, "op": "sharpen", "weight": 1.3},
                    {"scale": 3, "op": "sharpen", "weight": 1.15},
                    {"scale": 4, "op": "passthrough"},
                    {"scale": 5, "op": "passthrough"},
                ],
            },
            mask={"mask_type": "luminance", "range_low": 0.15,
                  "range_high": 1.0, "feather_radius": 8},
            blend_alpha=1.0,
        )

    Example — gently lift the faint outer shells only:
        masked_process(
            tool_name="curves_adjust",
            tool_params={
                "method": "ght",
                "ght_options": {"stretch_amount": 0.8, "symmetry_point": 0.18,
                                "local_intensity": 8, "highlight_protection": 0.95},
            },
            mask={"mask_type": "range", "range_low": 0.05, "range_high": 0.35,
                  "feather_radius": 12},
            blend_alpha=0.85,
        )

    Implementation outline
    ----------------------
    1. Resolve mask: if `mask` is a path, load it; if dict/MaskSpec, call the
       existing create_mask implementation to materialize a mask FITS.
    2. Snapshot the pre-processing image path.
    3. Invoke the primary tool via its import (tool_name → registered callable).
       The tool writes a new FITS and updates state.paths.current_image.
    4. Build a pixel_math expression:
          blend = processed * (mask * blend_alpha) + original * (1 - mask * blend_alpha)
    5. Run pixel_math with inputs {original, processed, mask}.
    6. Update state.paths.current_image to the blended output.
    7. Return the blended path + a metrics diff (pre vs post on the in-mask region).
    """
    # --- PROTOTYPE BODY (not executable as-is) ---
    # Real implementation delegates to existing tool functions by name.
    # Pseudocode:
    #
    #     from muphrid.graph.registry import all_tools
    #     primary = next(t for t in all_tools() if t.name == tool_name)
    #
    #     pre_path = state["paths"]["current_image"]
    #     mask_path = _resolve_or_materialize_mask(mask, state)
    #
    #     primary_result = primary.invoke({**tool_params, "state": state, ...})
    #     processed_path = _extract_output_path(primary_result)
    #
    #     blend_expr = f"$processed$ * $mask$ * {blend_alpha} + $pre$ * (1 - $mask$ * {blend_alpha})"
    #     blended = run_pixel_math(...)
    #
    #     return Command(update={...})
    raise NotImplementedError("Prototype stub — see docstring for the intended wiring.")
