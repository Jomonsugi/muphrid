# ─────────────────────────────────────────────────────────────────────────────
# .env  —  non-secret configuration (binary paths, model names, project settings)
#
# SECRETS LIVE IN ~/.zshrc, NOT HERE.
# The following variables are expected in your shell environment:
#
#   TOGETHER_API_KEY      (required when LLM_PROVIDER=together)
#   ANTHROPIC_API_KEY     (required when LLM_PROVIDER=anthropic)
#   OPENAI_API_KEY        (required when LLM_PROVIDER=openai)
#   LANGCHAIN_API_KEY     (optional — LangSmith tracing)
#   LANGCHAIN_TRACING_V2  (optional — set to "true" to enable LangSmith)
#
# Copy this file to .env and fill in the values below.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=together
LLM_MODEL=moonshotai/Kimi-K2.5
LLM_TEMPERATURE=0

# ── External binaries ───────────────────────────────────────────────────────────
# Override if not on the default PATH location.
SIRIL_BIN=/Applications/Siril.app/Contents/MacOS/siril-cli
GRAXPERT_BIN=/Applications/GraXpert.app/Contents/MacOS/GraXpert

# ── StarNet ─────────────────────────────────────────────────────────────────────
# Absolute path to the starnet2 executable (MPS-accelerated PyTorch build preferred).
# Download: https://www.starnetastro.com/download/
# After download:
#   chmod +x starnet2
#   xattr -d com.apple.quarantine starnet2
#   Allow in System Settings > Privacy & Security
#   codesign --force --sign - /path/to/starnet2
STARNET_BIN=/Users/your-username/Developer/starnet2-mps/starnet2

# Absolute path to the StarNet2 weights file (ships in the same folder as the binary).
STARNET_WEIGHTS=/Users/your-username/Developer/starnet2-mps/StarNet2_weights.pt

# ── Equipment ──────────────────────────────────────────────────────────────────
# Equipment data (camera pixel size, focal length, etc.) is now maintained in
# equipment.toml at the project root. Edit that file when you change gear.
# The env var below is only used as a fallback if equipment.toml is missing.
# PIXEL_SIZE_UM=3.76

# ── LangSmith ──────────────────────────────────────────────────────────────────
LANGCHAIN_PROJECT=astro-agent
