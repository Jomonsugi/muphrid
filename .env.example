# ── LLM ────────────────────────────────────────────────────────────────────────
# Together AI (default — OpenAI-compatible API, try any model on their platform)
TOGETHER_API_KEY=your-together-key-here
LLM_MODEL=moonshotai/Kimi-K2.5
LLM_TEMPERATURE=0

# Anthropic (optional — swap by setting LLM_PROVIDER=anthropic below)
ANTHROPIC_API_KEY=

# Which provider to use: together | anthropic | openai
# together uses OpenAI-compatible base_url pointing at api.together.xyz
LLM_PROVIDER=together

# ── External binaries ───────────────────────────────────────────────────────────
# Override if not on PATH
# Full path if installed from official .dmg (not Homebrew)
SIRIL_BIN=/Applications/Siril.app/Contents/MacOS/siril-cli
GRAXPERT_BIN=/Applications/GraXpert.app/Contents/MacOS/GraXpert

# ── StarNet ─────────────────────────────────────────────────────────────────────
STARNET_BIN=/Users/micahshanks/Developer/starnet2-mps/starnet2

# ── LangSmith (optional — for tracing / debugging) ─────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=astro-agent
